---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLatestRelease } from "../lib/release.ts";

const release = await getLatestRelease();
---
<BaseLayout title="Download OpenIT">
  <h1>Download OpenIT</h1>
  <p class="lede">
    macOS beta &middot; v{release.version}
    {release.releaseUrl && (
      <>
        &middot; <a href={release.releaseUrl}>release notes</a>
      </>
    )}
  </p>

  <div class="cta-row">
    <a
      class="btn"
      href={release.arm64DmgUrl ?? "#"}
      aria-disabled={release.arm64DmgUrl ? "false" : "true"}
    >
      {release.arm64DmgUrl ? "Apple Silicon" : "Apple Silicon — coming soon"}
      <span class="sub">M1, M2, M3, M4</span>
    </a>
    <a
      class="btn secondary"
      href={release.x64DmgUrl ?? "#"}
      aria-disabled={release.x64DmgUrl ? "false" : "true"}
    >
      {release.x64DmgUrl ? "Intel Mac" : "Intel — coming soon"}
      <span class="sub">x86_64</span>
    </a>
  </div>

  <p>
    <a href="https://support.apple.com/en-us/HT211814">Not sure which Mac you have?</a>
  </p>

  <h2>First-time install on macOS</h2>
  <div class="callout">
    <p>
      <strong>You'll see <em>"OpenIT can't be opened because Apple cannot check
      it for malicious software."</em></strong> That's expected for the beta —
      we're in the process of getting an Apple Developer ID, after which this
      step will go away.
    </p>
    <p>To open OpenIT, do this once:</p>
    <ol>
      <li>Drag <strong>OpenIT.app</strong> from the DMG into <strong>/Applications</strong>.</li>
      <li>Open <strong>System Settings &rarr; Privacy &amp; Security</strong>.</li>
      <li>Scroll down to the <em>Security</em> section. You'll see a line about OpenIT being blocked. Click <strong>Open Anyway</strong>.</li>
      <li>Confirm in the dialog that follows. OpenIT will launch normally from now on.</li>
    </ol>
    <p>
      Prefer the terminal? Run <code>xattr -cr /Applications/OpenIT.app</code>
      and then double-click the app.
    </p>
    <details>
      <summary>Why does this happen?</summary>
      <p>
        macOS Gatekeeper requires apps distributed outside the App Store to be
        signed with an Apple Developer ID and notarized by Apple. We're working
        through Apple's organization enrollment for Pinkfish; once that's done,
        future versions will install without this prompt and existing users
        will be auto-updated to the signed build.
      </p>
    </details>
  </div>

  <h2>Updates</h2>
  <p>
    OpenIT checks for updates on launch and offers to install them in-place. You
    don't need to come back to this page — the first install is the only manual
    step.
  </p>
</BaseLayout>
