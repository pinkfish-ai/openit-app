---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const url = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;

const githubUrl = "https://github.com/pinkfish-ai/openit-app";

const nativeAccess: { k: string; v: string }[] = [
  { k: "Identity", v: "Okta · Google Workspace · Microsoft Entra" },
  { k: "Chat", v: "Slack · Microsoft Teams" },
  { k: "Endpoints", v: "Jamf · Kandji · Intune" },
  { k: "Cloud", v: "AWS · GCP · Azure" },
  { k: "Code", v: "GitHub · GitLab" },
  { k: "Tickets & docs", v: "Jira · Linear · Notion · Confluence" },
];
---
<BaseLayout title="OpenIT — An IT helpdesk that runs on Claude Code" bare={true}>
  <div>
    {/* HERO */}
    <section class="mx-auto max-w-7xl px-6 pb-20 pt-10 md:px-10 md:pb-32 md:pt-16">
      <span class="inline-flex items-center gap-2 rounded-full border border-ink/15 bg-cream px-4 py-1.5 font-mono-tag text-[11px] text-ink/70">
        <span class="h-1.5 w-1.5 rounded-full bg-terracotta"></span>
        Public Beta · macOS · Open Source
      </span>

      <h1 class="font-display mt-8 text-[9.5vw] leading-[0.95] md:mt-10 md:text-[68px] lg:text-[88px]">
        An IT helpdesk{" "}
        <span class="text-terracotta">that runs on Claude Code.</span>
      </h1>

      <p class="mt-10 max-w-3xl text-xl leading-snug text-ink/80 md:text-2xl">
        Claude handles tickets, provisions access, and{" "}
        <span class="font-serif-italic text-terracotta">learns how you work</span> — so you spend your day on the hard problems, not the queue.
      </p>

      <div id="download" class="mt-12 flex flex-wrap items-center gap-4">
        <a href={url("/download")} class="group inline-flex items-center gap-3 rounded-full bg-ink px-7 py-4 text-cream transition hover:bg-terracotta no-underline">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06z"/><path d="M10 2c1 .5 2 2 2 5"/></svg>
          <span class="font-medium">Download for macOS</span>
          <span class="font-mono-tag text-[10px] text-cream/60">Beta · AS + Intel</span>
        </a>
        <a href={githubUrl} class="group inline-flex items-center gap-2 rounded-full border border-ink/20 bg-transparent px-7 py-4 text-ink transition hover:border-ink hover:bg-ink hover:text-cream no-underline">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          <span class="font-medium">View on GitHub</span>
          <svg class="h-4 w-4 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>

      {/* Architecture block */}
      <div class="mt-24 grid gap-px overflow-hidden rounded-3xl border border-ink/15 bg-ink/15 md:mt-32 md:grid-cols-2">
        <div class="bg-cream p-8 md:p-10">
          <div class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-cream-deep px-3 py-1.5 font-mono-tag text-[11px] font-semibold text-ink">
            <svg class="h-3.5 w-3.5 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="m4 17 6-6-6-6"/><path d="M12 19h8"/></svg>
            For IT · Desktop App
          </div>
          <h3 class="font-display mt-6 text-4xl leading-[0.95] tracking-tight md:text-5xl">
            Run Claude Code <br /> on your desktop.
          </h3>
          <p class="mt-5 max-w-md text-base leading-relaxed text-ink/70">
            Install OpenIT on your Mac. Claude works alongside you in the terminal — reading tickets, shaping workflows, writing connectors.
          </p>
          <div class="mt-8 rounded-xl bg-ink p-4 font-mono-tag text-[11px] text-cream/80">
            <div class="text-cream/40">$ openit start</div>
            <div class="mt-2 text-terracotta">→ claude code · ready</div>
            <div class="text-cream/60">→ slack · connected</div>
            <div class="text-cream/60">→ 12 open tickets in queue</div>
          </div>
        </div>
        <div class="bg-cream-deep p-8 md:p-10">
          <div class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-cream px-3 py-1.5 font-mono-tag text-[11px] font-semibold text-ink">
            <svg class="h-3.5 w-3.5 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            For Employees · Chat
          </div>
          <h3 class="font-display mt-6 text-4xl leading-[0.95] tracking-tight md:text-5xl">
            Ask in Slack, <br /> Teams, or email.
          </h3>
          <p class="mt-5 max-w-md text-base leading-relaxed text-ink/70">
            No new app to learn. Employees ask wherever they already work — Claude answers, or routes it to you.
          </p>
          <div class="mt-8 space-y-3">
            <div class="max-w-[85%] rounded-2xl bg-ink/5 p-4">
              <div class="font-mono-tag text-[10px] text-ink/40">marcus · #it-help</div>
              <div class="mt-1 text-sm text-ink/80">need access to the analytics dashboard please</div>
            </div>
            <div class="ml-auto max-w-[85%] rounded-2xl bg-terracotta p-4 text-cream">
              <div class="font-mono-tag text-[10px] text-cream/60">openit · just now</div>
              <div class="mt-1 text-sm">Granted — Looker viewer role added. Try refreshing.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* §01 THESIS */}
    <section id="thesis" class="border-t border-ink/10">
      <div class="mx-auto grid max-w-7xl gap-16 px-6 py-24 md:grid-cols-12 md:px-10 md:py-32">
        <div class="md:col-span-5">
          <div class="flex items-center gap-3 font-mono-tag text-[11px] text-ink/50">
            <span class="text-terracotta">§01</span>
            <span class="h-px flex-1 bg-ink/15"></span>
            <span>The thesis</span>
          </div>
          <h2 class="font-display mt-6 text-5xl leading-[0.95] tracking-tight md:text-6xl">
            Configure in <br /> Claude Code. <br />
            <span class="text-terracotta">Not UI.</span>
          </h2>
        </div>
        <div class="space-y-8 md:col-span-7 md:pt-20">
          <p class="text-xl leading-relaxed text-ink/75 md:text-2xl">
            Every other ITSM is configured the same way: clicky admin screens, proprietary workflow builders, vendor agents you have to learn. The configuration is theirs.
          </p>
          <blockquote class="border-l-2 border-terracotta pl-6 font-display text-3xl leading-tight tracking-tight md:text-4xl">
            Claude Code is the operating system.
          </blockquote>
          <p class="text-lg leading-relaxed text-ink/75">
            OpenIT inverts it. You configure in plain English with Claude Code; the result is plain files on your machine. Open them. Edit them. Take them with you.
          </p>
        </div>
      </div>
    </section>

    {/* §02 NATIVE ACCESS */}
    <section id="native-access" class="border-t border-ink/10 bg-cream-deep">
      <div class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
        <div class="flex items-center gap-3 font-mono-tag text-[11px] text-ink/50">
          <span class="text-terracotta">§02</span>
          <span class="h-px flex-1 bg-ink/15"></span>
          <span>Native access</span>
        </div>
        <h2 class="font-display mt-6 text-5xl leading-[0.95] tracking-tight md:text-7xl">
          Every tool. <br />
          <span class="font-serif-italic text-terracotta">One chat.</span>
        </h2>
        <p class="mt-10 max-w-3xl text-xl leading-snug text-ink/75 md:text-2xl">
          Stop logging into five dashboards. Claude has direct access to every system you use — so you ask in one place, and it acts everywhere.
        </p>

        <div class="mt-16 grid gap-px overflow-hidden rounded-3xl border border-ink/15 bg-ink/15 md:grid-cols-3">
          {nativeAccess.map(({ k, v }) => (
            <div class="bg-cream p-6 md:p-7">
              <div class="font-mono-tag text-[10px] text-terracotta">{k}</div>
              <div class="mt-3 text-base leading-snug text-ink md:text-lg">{v}</div>
            </div>
          ))}
          <div class="bg-ink p-6 text-cream md:col-span-3 md:p-8">
            <div class="flex flex-col items-start gap-4 md:flex-row md:items-center md:justify-between">
              <div class="flex items-center gap-3">
                <svg class="h-4 w-4 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M12 22v-5"/><path d="M9 7V2"/><path d="M15 7V2"/><path d="M6 13V8h12v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4Z"/></svg>
                <div class="font-mono-tag text-[10px] text-terracotta">Anything else</div>
              </div>
              <div class="text-base leading-snug text-cream/85 md:text-lg">
                Claude writes the integration if it's missing.
              </div>
            </div>
          </div>
        </div>

        <p class="mt-12 max-w-3xl text-lg leading-relaxed text-ink/70">
          No middleware. No glue scripts. No tab-switching. The investigation, the fix, and the article that documents it all happen in one conversation.
        </p>
      </div>
    </section>

    {/* §03 HOW IT LEARNS */}
    <section id="learns" class="border-t border-ink/10 bg-ink text-cream">
      <div class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
        <div class="flex items-center gap-3 font-mono-tag text-[11px] text-cream/40">
          <span class="text-terracotta">§03</span>
          <span class="h-px flex-1 bg-cream/15"></span>
          <span>How it learns</span>
        </div>
        <h2 class="font-display mt-6 max-w-5xl text-5xl leading-[0.95] tracking-tight md:text-7xl">
          Answer once. <br /><span class="font-serif-italic text-terracotta">Claude handles the next one.</span>
        </h2>
        <p class="mt-10 max-w-2xl text-xl leading-snug text-cream/70 md:text-2xl">
          The first time someone asks something Claude hasn't seen, it escalates to you. After you answer, Claude captures the answer <span class="font-serif-italic text-terracotta">and</span> the workflow — so the next time, it just handles it.
        </p>

        <div class="mx-auto mt-20 max-w-3xl rounded-3xl border border-cream/10 bg-cream/[0.03] p-6 md:p-10">
          <div class="font-mono-tag text-[10px] text-cream/40">Day 1 · #it-help</div>
          <div class="mt-5 space-y-4">
            <div class="max-w-[80%] rounded-2xl bg-cream/10 p-4">
              <div class="font-mono-tag text-[10px] text-cream/40">marcus</div>
              <div class="mt-1 text-base text-cream/90">i can't log in</div>
            </div>
            <div class="ml-auto max-w-[85%] rounded-2xl border border-terracotta/30 bg-terracotta/10 p-4">
              <div class="font-mono-tag text-[10px] text-terracotta">openit · escalating to you</div>
              <div class="mt-1 text-base text-cream/85">Haven't seen this one before.</div>
            </div>
            <div class="max-w-[85%] rounded-2xl bg-cream/10 p-4">
              <div class="font-mono-tag text-[10px] text-cream/40">you</div>
              <div class="mt-1 text-base text-cream/90">reset your password at company.okta.com/reset</div>
            </div>
          </div>

          {/* Saved automation marker */}
          <div class="my-6 flex items-center gap-4 rounded-2xl border-2 border-dashed border-terracotta/50 bg-terracotta/5 p-5">
            <svg class="h-7 w-7 flex-shrink-0 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M20 6 9 17l-5-5"/></svg>
            <div class="min-w-0 flex-1">
              <div class="font-mono-tag text-[10px] uppercase tracking-wider text-terracotta">Automation saved</div>
              <div class="mt-1 truncate font-mono-tag text-[12px] text-cream/85">skills/login-reset.md · KB article published</div>
            </div>
          </div>

          <div class="my-6 flex items-center gap-3 font-mono-tag text-[10px] text-cream/40">
            <span class="h-px flex-1 bg-cream/15"></span>
            <span>three days later</span>
            <span class="h-px flex-1 bg-cream/15"></span>
          </div>

          <div class="space-y-4">
            <div class="max-w-[80%] rounded-2xl bg-cream/10 p-4">
              <div class="font-mono-tag text-[10px] text-cream/40">priya</div>
              <div class="mt-1 text-base text-cream/90">can't log in either, what do i do</div>
            </div>
            <div class="ml-auto max-w-[85%] rounded-2xl bg-terracotta p-4 text-cream">
              <div class="font-mono-tag text-[10px] text-cream/60">openit · auto-resolved</div>
              <div class="mt-1 text-base">Reset your password at company.okta.com/reset.</div>
            </div>
          </div>
        </div>

        <p class="mt-16 max-w-3xl text-lg leading-relaxed text-cream/70">
          Every question Claude can't answer becomes a saved automation. Two weeks in, your queue runs differently.
        </p>
      </div>
    </section>

    {/* §04 SKILLS AND SCRIPTS */}
    <section class="border-t border-ink/10">
      <div class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
        <div class="flex items-center gap-3 font-mono-tag text-[11px] text-ink/50">
          <span class="text-terracotta">§04</span>
          <span class="h-px flex-1 bg-ink/15"></span>
          <span>What gets saved</span>
        </div>
        <h2 class="font-display mt-6 max-w-5xl text-5xl leading-[0.95] tracking-tight md:text-7xl">
          Done once. <br /><span class="font-serif-italic text-terracotta">Saved forever.</span>
        </h2>
        <p class="mt-10 max-w-3xl text-xl leading-snug text-ink/75 md:text-2xl">
          Each fix becomes a file you can read, edit, and reuse — plain instructions when that's enough, code when it's not.
        </p>

        <div class="mt-16 grid gap-8 md:grid-cols-2">
          {/* Skill — markdown */}
          <div class="overflow-hidden rounded-3xl border border-ink/15 bg-cream">
            <div class="flex items-center gap-2 border-b border-ink/10 bg-cream-deep px-5 py-3 font-mono-tag text-[11px] text-ink/60">
              <svg class="h-3.5 w-3.5 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              skills/login-reset.md
            </div>
            <div class="p-6 md:p-8 font-mono-tag text-[12.5px] leading-relaxed text-ink/85">
              <div class="text-terracotta"># Login &amp; password reset</div>
              <div class="mt-3 text-ink/60">When someone says they can't log in:</div>
              <div class="mt-3">1. Confirm their email is on file</div>
              <div>2. Send the reset link from company.okta.com/reset</div>
              <div>3. If no email arrives in 5 min, escalate</div>
            </div>
            <div class="border-t border-ink/10 bg-cream-deep px-5 py-3 font-mono-tag text-[10px] uppercase tracking-wider text-ink/50">
              Skill · plain English
            </div>
          </div>

          {/* Script — code */}
          <div class="overflow-hidden rounded-3xl bg-ink text-cream">
            <div class="flex items-center gap-2 border-b border-cream/10 bg-cream/[0.04] px-5 py-3 font-mono-tag text-[11px] text-cream/60">
              <svg class="h-3.5 w-3.5 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              scripts/offboard.ts
            </div>
            <div class="p-6 md:p-8 font-mono-tag text-[12.5px] leading-relaxed text-cream/85">
              <div><span class="text-terracotta">async function</span> offboard(email) &#123;</div>
              <div class="pl-4">await okta.deactivate(email)</div>
              <div class="pl-4">await jamf.unenroll(email)</div>
              <div class="pl-4">await drive.transferOwnership(email)</div>
              <div class="pl-4">await slack.archiveDMs(email)</div>
              <div>&#125;</div>
            </div>
            <div class="border-t border-cream/10 bg-cream/[0.04] px-5 py-3 font-mono-tag text-[10px] uppercase tracking-wider text-cream/50">
              Script · for code
            </div>
          </div>
        </div>

        <p class="mt-12 max-w-3xl text-lg leading-relaxed text-ink/70">
          Claude builds them. Then runs them — when you ask, or automatically when a familiar request comes in.
        </p>
      </div>
    </section>

    {/* §05 LOCAL → CLOUD */}
    <section class="border-t border-ink/10 bg-cream-deep">
      <div class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
        <div class="flex items-center gap-3 font-mono-tag text-[11px] text-ink/50">
          <span class="text-terracotta">§05</span>
          <span class="h-px flex-1 bg-ink/15"></span>
          <span>Local, then cloud</span>
        </div>
        <h2 class="font-display mt-6 text-5xl leading-[0.95] tracking-tight md:text-7xl">
          Try it on your Mac. <br /> <span class="font-serif-italic text-terracotta">Deploy when you trust it.</span>
        </h2>

        <div class="mt-16 grid items-stretch gap-6 md:grid-cols-[1fr_auto_1fr] md:gap-4">
          <div class="rounded-3xl border border-ink/15 bg-cream p-8 md:p-10">
            <div class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-cream-deep px-3 py-1 font-mono-tag text-[11px] font-medium text-ink">
              <span class="h-1.5 w-1.5 rounded-full bg-ink"></span>
              01 · Local
            </div>
            <h3 class="font-display mt-5 text-3xl tracking-tight md:text-4xl">On your Mac.</h3>
            <p class="mt-4 leading-relaxed text-ink/70">
              Run OpenIT on your laptop. Real Claude Code, real integrations, real tickets — no paid sandbox. Try it for as long as you need.
            </p>
          </div>

          {/* Arrow */}
          <div class="flex items-center justify-center text-terracotta">
            <svg class="h-8 w-8 rotate-90 md:rotate-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>

          <div class="rounded-3xl bg-ink p-8 text-cream md:p-10">
            <div class="inline-flex items-center gap-2 rounded-full border border-terracotta/40 bg-terracotta/10 px-3 py-1 font-mono-tag text-[11px] font-medium text-terracotta">
              <span class="h-1.5 w-1.5 rounded-full bg-terracotta"></span>
              02 · Cloud
            </div>
            <h3 class="font-display mt-5 text-3xl tracking-tight md:text-4xl">Sync to Pinkfish.</h3>
            <p class="mt-4 leading-relaxed text-cream/70">
              When it earns your trust, sync to cloud. The same project runs 24/7 — Slack and Teams stay live, agents act while you sleep, public links stay reachable.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* §06 STATUS */}
    <section id="status" class="border-t border-ink/10 bg-terracotta text-cream">
      <div class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-40">
        <div class="flex items-center gap-3 font-mono-tag text-[11px] text-cream/60">
          <span>§06</span>
          <span class="h-px flex-1 bg-cream/30"></span>
          <span>Status</span>
        </div>
        <h2 class="font-display mt-6 text-7xl leading-[0.92] tracking-tight md:text-[112px]">
          Public <span class="font-serif-italic">beta.</span>
        </h2>
        <p class="mt-10 max-w-2xl text-xl leading-snug text-cream/85 md:text-2xl">
          macOS (Apple Silicon + Intel), signed and notarized — no first-launch warning. Linux and Windows builds follow.
        </p>
        <div class="mt-12">
          <a href={url("/download")} class="group inline-flex items-center gap-3 rounded-full bg-ink px-7 py-4 text-cream transition hover:bg-cream hover:text-ink no-underline">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06z"/><path d="M10 2c1 .5 2 2 2 5"/></svg>
            <span class="font-medium">Download for macOS</span>
            <span class="font-mono-tag text-[10px] opacity-70">Beta · AS + Intel</span>
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
