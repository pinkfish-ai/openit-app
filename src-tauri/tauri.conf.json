{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenIT",
  "version": "0.1.0",
  "identifier": "ai.pinkfish.openit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenIT",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "http": {
      "allow": [
        "https://dev*.pinkfish.dev/**",
        "https://dev*.pinkfish.ai/**",
        "https://app.pinkfish.ai/**",
        "https://app-stage.pinkfish.ai/**"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
