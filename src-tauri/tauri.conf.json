{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenIT",
  "version": "0.1.0",
  "identifier": "ai.pinkfish.openit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenIT",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../scripts/openit-plugin/manifest.json": "openit-plugin/manifest.json",
      "../scripts/openit-plugin/CLAUDE.md": "openit-plugin/CLAUDE.md",
      "../scripts/openit-plugin/skills/*.md": "openit-plugin/skills/",
      "../scripts/openit-plugin/schemas/*.json": "openit-plugin/schemas/",
      "../scripts/openit-plugin/agents/*.json": "openit-plugin/agents/",
      "../scripts/openit-plugin/scripts/*.mjs": "openit-plugin/scripts/",
      "../scripts/openit-plugin/scripts/slack-listen.bundle.cjs": "openit-plugin/scripts/slack-listen.bundle.cjs"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
